# Public DNS name pointing to the deployment server. Do not include https://.
DOMAIN=refundweave.example.com

# Use URL-safe random values because MYSQL_PASSWORD is embedded in a database URL.
MYSQL_PASSWORD=replace_with_url_safe_random_value
MYSQL_ROOT_PASSWORD=replace_with_a_different_random_value

OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LOG_LEVEL=INFO
CHAT_RATE_LIMIT_REQUESTS=12
CHAT_RATE_LIMIT_WINDOW_SECONDS=60

# Monitoring binds to localhost; use an SSH tunnel instead of exposing these ports.
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_a_strong_dashboard_password

# Pin these to the same release version for repeatable deployments, for example 1.0.0.
REFUNDWEAVE_API_IMAGE=ghcr.io/usman00711/refundweave-api:latest
REFUNDWEAVE_WEB_IMAGE=ghcr.io/usman00711/refundweave-web:latest
